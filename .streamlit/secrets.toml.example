# =============================================================================
# Streamlit secrets — example file
#
# Copy this file to `.streamlit/secrets.toml` and fill in real values for local
# development. On Streamlit Cloud, paste the same contents into the
# "App settings → Secrets" panel instead — never commit a real secrets.toml.
#
# `.streamlit/secrets.toml` is gitignored.
# =============================================================================

# Password used to unlock the admin panel (Add / Edit / Delete references).
# Pick a long, random string — at least 16 characters. Rotate immediately if
# you suspect it's been exposed.
#
# The previous default ("admin123") is permanently considered compromised
# because it lived in the public Git history. Do not reuse it.
ADMIN_PASSWORD = "change-me-to-a-long-random-string"
